# ── Chatbot Configuration ──────────────────────────────────────────────────
# Mode de fonctionnement du chatbot (par ordre de priorité)

# 1. Deep Learning Model (recommandé pour le projet)
USE_DL_MODEL=true          # true = utilise RAG + Fine-tuned GPT-2

# 2. Fallback modes (si DL model non disponible)
USE_OLLAMA=true            # true = Ollama local, false = Groq API
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE